@model IEnumerable<AspKutuphane.Models.Book>

    @{
    ViewData["Title"] = "Kitap Listesi";
    var activeUserEmail = Context.Request.Cookies["ActiveUserEmail"];
    }

    <style>
        /* 1. Arka plan katmanı */
        .bg-image-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
                url('/images/1.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            z-index: -1;
        }

        /* 2. BEYAZ KART TASARIMI */
        .book-horizontal-card {
            background-color: rgba(255, 255, 255, 0.95) !important;
            border: none;
            border-radius: 15px;
            transition: all 0.3s ease;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .book-horizontal-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3) !important;
            background-color: #ffffff !important;
        }

        .book-image-container {
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 200px;
            border-right: 1px solid #eee;
        }

        .book-title {
            color: #212529;
            font-weight: 700;
        }

        .book-info-text {
            color: #6c757d;
        }
    </style>

    <div class="bg-image-overlay"></div>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white fw-bold mb-0">📚 Kütüphane Arşivi</h2>
            <span class="badge bg-light text-dark px-3 py-2 shadow-sm fw-bold">@(Model?.Count() ?? 0) Kitap
                Listeleniyor</span>
        </div>

        @if (Model == null || !Model.Any())
        {
        <div class="alert alert-light border-0 shadow-sm text-center p-5">
            <i class="bi bi-book fs-1 d-block mb-3 text-muted"></i>
            Kütüphanede henüz kitap bulunmuyor.
        </div>
        }
        else
        {
        <div class="row">
            @foreach (var item in Model)
            {
            <div class="col-12 mb-4">
                <div class="book-horizontal-card shadow-sm">
                    <div class="row g-0">
                        @* SOL TARAF: Resim Alanı *@
                        <div class="col-md-2 book-image-container">
                            @if (!string.IsNullOrEmpty(item.Image))
                            {
                            <img src="~/images/@item.Image" class="img-fluid" alt="@item.Title"
                                style="height: 170px; object-fit: contain; padding: 15px;">
                            }
                            else
                            {
                            <i class="bi bi-book-fill text-light-emphasis" style="font-size: 3.5rem;"></i>
                            }
                        </div>

                        @* SAĞ TARAF: Kitap Bilgileri *@
                        <div class="col-md-10">
                            <div class="card-body h-100 d-flex flex-column justify-content-between p-4">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h4 class="book-title mb-1">@item.Title</h4>
                                        @if (item.IsBorrowed)
                                        {
                                        <span
                                            class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3">
                                            <i class="bi bi-x-circle me-1"></i> Ödünç Verildi
                                        </span>
                                        }
                                        else
                                        {
                                        <span
                                            class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3">
                                            <i class="bi bi-check2-circle me-1"></i> Mevcut
                                        </span>
                                        }
                                    </div>
                                    <p class="book-info-text mb-0 small">Kayıt No: #@item.Id</p>
                                </div>

                                <div class="d-flex justify-content-end align-items-center gap-2">
    @if (!string.IsNullOrEmpty(activeUserEmail) && !item.IsBorrowed)
    {
        @* ÖDÜNÇ AL BUTONU *@
        <a asp-action="Borrow" asp-controller="Book" asp-route-id="@item.Id"
           class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm">
            Ödünç Al
        </a>
    }

    @* GÜNCELLE BUTONU (Değişken ismi item.Id olarak düzeltildi ve tasarıma uyarlandı) *@
    <a asp-controller="Book" asp-action="Edit" asp-route-id="@item.Id"
       class="btn btn-warning btn-sm rounded-pill px-4 fw-bold shadow-sm">
        Güncelle
    </a>

    @* İNCELE BUTONU *@
    <a asp-action="Details" asp-route-id="@item.Id"
       class="btn btn-outline-secondary btn-sm rounded-pill px-4 fw-bold">
        İncele
    </a>
</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>
        }
    </div>