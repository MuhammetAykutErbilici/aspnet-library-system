@{
ViewData["Title"] = "Ana Sayfa";
var activeUserEmail = Context.Request.Cookies["ActiveUserEmail"];
}

<style>
    /* 1. Sayfanın tamamında scrollbar'ı kapatır */
    html,
    body {
        overflow: hidden;
        /* Kaydırmayı engeller */
        height: 100%;
        margin: 0;
        padding: 0;
    }

    /* 2. Arka plan katmanı */
    .bg-image-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
            url('/images/1.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: -1;
    }

    /* 3. Ana içerik kutusu */
    .hero-glass-card {
        background-color: rgba(255, 255, 255, 0.95) !important;
        border-radius: 20px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        padding: 50px 30px;
        backdrop-filter: blur(10px);
        border: none;
    }

    .hero-title {
        color: #212529;
        font-weight: 800;
        font-size: calc(1.5rem + 2vw);
        /* Ekran boyutuna göre dinamik font */
    }

    .hero-subtitle {
        color: #495057;
        font-size: 1.2rem;
    }
</style>

<div class="bg-image-overlay"></div>

<div class="container-fluid">
    @* Ekranı dikeyde tam ortalamak için vh-100 kullanıyoruz *@
    <div class="row justify-content-center align-items-center" style="height: 75vh;">
        <div class="col-lg-8 col-md-10">
            <div class="hero-glass-card text-center shadow-lg">

                <h1 class="hero-title mb-3">Dijital Kütüphane Yönetimi</h1>

                <p class="hero-subtitle mb-4 mx-auto" style="max-width: 700px;">
                    Binlerce kitap, sınırsız bilgi. Kütüphane deneyiminizi modern teknolojilerle dijitale taşıyın ve
                    yönetin.
                </p>

                <div class="d-flex flex-wrap justify-content-center gap-3">
                    @if (string.IsNullOrEmpty(activeUserEmail))
                    {
                    <a asp-controller="Account" asp-action="Register"
                        class="btn btn-primary btn-lg px-5 py-2 shadow-sm fw-bold rounded-pill">
                        Üye Ol
                    </a>
                    <a asp-controller="Account" asp-action="Login"
                        class="btn btn-outline-primary btn-lg px-5 py-2 fw-bold rounded-pill">
                        Giriş Yap
                    </a>
                    <a asp-controller="Book" asp-action="Index"
                        class="btn btn-light btn-lg px-5 py-2 shadow-sm border rounded-pill">
                        Kitapları İncele
                    </a>
                    }
                    else
                    {
                    <div class="w-100">
                        <h4 class="text-dark mb-3 fw-bold">Hoş geldin!</h4>
                        <a asp-controller="Book" asp-action="Index"
                            class="btn btn-primary btn-lg px-5 py-3 shadow-lg rounded-pill" style="min-width: 250px;">
                            <i class="bi bi-search me-2"></i>Kitapları İncele
                        </a>
                    </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>